table Sales_Data
	lineageTag: 318e10e0-7eb3-467f-9e4d-04b0d91ebe0a

	measure 'Total Revenue' = SUM(Sales_Data[NetSales])
		lineageTag: a983f973-4604-4a0f-8050-3dcf9d67d8ef

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Profit' = SUM(Sales_Data[Profit])
		lineageTag: 849b8e99-a7ef-4462-bf22-663e056c61cc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Order' = COUNT(Sales_Data[SalesID])
		formatString: 0
		lineageTag: db0353a4-096a-4aed-acf0-d70d30635e4f

	measure 'Avg Order Value' = DIVIDE([Total Revenue],[Total Order],0)
		lineageTag: cbb1043a-359c-47b4-9df8-326df0639e87

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Profit Margin %' = DIVIDE([Total Profit], [Total Revenue], 0) * 100
		lineageTag: 0e305538-a1d9-464b-9889-e3057846901a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cancellation rate %' = DIVIDE(CALCULATE([Total Order],Sales_Data[OrderStatus] ="Cancelled"),[Total Order],0)*100
		lineageTag: 4dd4c7e2-0a1a-43ab-aef0-5596fb53c471

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Return rate %' = DIVIDE(CALCULATE([Total Order],Sales_Data[OrderStatus] ="Returned"),[Total Order],0)*100
		lineageTag: ac2f7c16-5e38-47f9-8bcf-6d1c54513071

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Revenue MoM Growth %' =
			
			VAR CurrentMonth = [Total Revenue]
			VAR Previous =
			    CALCULATE(
			        [Total Revenue],
			        DATEADD(DateTable[Date], -1, MONTH)
			    )
			RETURN
			    DIVIDE(CurrentMonth - Previous, Previous, 0) * 100
		lineageTag: a5dd9247-b835-4b65-8e6e-19fcdba934a1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Revenue YoY Growth %' =
			
			DIVIDE(
			    [Total Revenue] - CALCULATE([Total Revenue], SAMEPERIODLASTYEAR(DateTable[Date])),
			    CALCULATE([Total Revenue], SAMEPERIODLASTYEAR(DateTable[Date])),
			    0
			) * 100
		lineageTag: c25128bd-131e-4520-ada7-7b0fb9f53eb4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Delivery Days' = AVERAGE(Sales_Data[DeliveryDays])
		lineageTag: 33eaa893-5d9b-4efd-bde6-c11f33f98db8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Festival Revenue' =
			
			CALCULATE([Total Revenue], Sales_Data[IsFestivalPeriod] = 1)
		lineageTag: b526f205-9863-4056-baa7-5a084db1d648

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Non Festival Revenue' =
			
			CALCULATE([Total Revenue], Sales_Data[IsFestivalPeriod] = 0)
		lineageTag: 09a19b17-b78e-4b53-a02f-542aeb44b1b1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

