		annotation SummarizationSetBy = Automatic

	partition DateTable = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        MIN(Sales_Data[OrderDate]),
				        MAX(Sales_Data[OrderDate])
				    ),
				    "Year",        YEAR([Date]),
				    "Month",       MONTH([Date]),
				    "MonthName",   FORMAT([Date], "MMM"),
				    "Quarter",     QUARTER([Date]),
				    "QuarterName", "Q" & QUARTER([Date]),
				    "YearMonth",   FORMAT([Date], "YYYY-MM"),
				    "WeekDay",     WEEKDAY([Date]),
				    "DayName",     FORMAT([Date], "DDD"))

	annotation PBI_Id = 061cb0f81da749519482bb774e4853f9

